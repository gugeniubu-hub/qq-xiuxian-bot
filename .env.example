DRIVER=~fastapi+~httpx+~websockets
HOST=127.0.0.1
PORT=8080

# Official QQ Open Platform bot. Fill this when using a created QQ robot.
# Public group bot webhook callback: https://your-domain/qxian/qq/webhook
QQ_IS_SANDBOX=false
QQ_VERIFY_WEBHOOK=true
QQ_BOTS='[{"id":"your_appid","token":"your_token","secret":"your_app_secret","intent":{"c2c_group_at_messages":true,"interaction":true},"use_websocket":true}]'

# OneBot / NapCat compatibility. Leave empty if using the official QQ bot above.
ONEBOT_ACCESS_TOKEN=
ONEBOT_SECRET=

COMMAND_START=["","/"]
COMMAND_SEP=["."]

QXIAN_DATABASE_URL=sqlite:///data/qxian.db
QXIAN_MARKET_FEE_RATE=0.05
QXIAN_DAILY_POOL_RELEASE_RATE=0.2
QXIAN_SQLITE_CONNECTION_POOL_SIZE=4
QXIAN_QQ_BUTTONS_ENABLED=true

# Optional AI narrator. Core game logic never depends on this.
QXIAN_LLM_ENABLED=false
QXIAN_LLM_PROVIDER=deepseek
QXIAN_LLM_BASE_URL=https://api.deepseek.com
QXIAN_LLM_MODEL=deepseek-v4-flash
QXIAN_LLM_API_KEY=
QXIAN_LLM_TIMEOUT_SECONDS=3
QXIAN_LLM_MAX_TOKENS=180
QXIAN_LLM_MAX_OUTPUT_CHARS=360
QXIAN_LLM_USER_COOLDOWN_SECONDS=5
QXIAN_LLM_DAILY_LIMIT=300
